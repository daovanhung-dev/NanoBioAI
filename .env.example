# BioAI Environment Variables Example
# Use these names with --dart-define or a local untracked launch profile.
# Do not commit real values and do not add .env to Flutter assets.

# ============================================================================
# Supabase Configuration
# ============================================================================
# Get these from: https://supabase.com/dashboard/project/_/settings/api
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-supabase-anon-key-here
AUTH_EMAIL_REDIRECT_URL=nanobio://auth/callback
AUTH_CONFIRM_EMAIL_REQUIRED=true
AUTH_DELETE_ACCOUNT_FUNCTION=delete-account

# ============================================================================
# Google Gemini AI Configuration
# ============================================================================
# Create and manage a Gemini API key in Google AI Studio.
GEMINI_API_KEY=your-gemini-api-key-here
GEMINI_BASE_URL=https://generativelanguage.googleapis.com/v1beta
GEMINI_CHAT_MODEL=gemini-3.1-flash-lite
GEMINI_CHAT_FALLBACK_MODELS=gemini-3.5-flash,gemini-2.5-flash-lite
GEMINI_PLAN_MODEL=gemini-3.1-flash-lite
GEMINI_PLAN_FALLBACK_MODELS=gemini-3.5-flash,gemini-2.5-flash-lite,gemini-2.5-flash
GEMINI_PLAN_OVERFLOW_MODELS=
# Legacy fallback keys are still supported when GEMINI_PLAN_* is absent.
# GEMINI_MODEL=gemini-3.1-flash-lite
# GEMINI_FALLBACK_MODELS=gemini-3.5-flash,gemini-2.5-flash-lite,gemini-2.5-flash
ONBOARDING_AI_DEV_CHECK_ENABLED=true

# ============================================================================
# Optional: Additional Services
# ============================================================================
# Add other API keys as needed through --dart-define or local secret storage.
# SENTRY_DSN=your-sentry-dsn
# FIREBASE_API_KEY=your-firebase-key
