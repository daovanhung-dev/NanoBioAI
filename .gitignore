# ============================================================================
# BioAI Flutter Project - .gitignore
# ============================================================================

# ============================================================================
# Environment & Secrets
# ============================================================================
# CRITICAL: Never commit secrets!
.env
.env.local
.env.*.local
*.env
secrets.json
firebase_options.dart

# API Keys & Credentials (be extra careful)
**/credentials/
**/secrets/
**/*_secret*
**/*_key.json
**/*_credentials.json

# ============================================================================
# Database Files
# ============================================================================
# Local SQLite database - should NOT be committed
*.db
*.db-shm
*.db-wal
*.sqlite
*.sqlite3
bioai.db

# Database backups
*.db.backup
*.sql.backup

# ============================================================================
# Flutter/Dart/Pub Related
# ============================================================================
