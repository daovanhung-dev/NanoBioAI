/build/
**/build/
.dart_tool/
.flutter-plugins
.flutter-plugins-dependencies
.packages
.pub-cache/
.pub/
pubspec.lock

# Coverage
/coverage/
*.lcov

# Documentation
**/doc/api/
**/docs/api/

# Flutter version management
.flutter-version

# Generated files
*.g.dart
*.freezed.dart
*.mocks.dart
*.config.dart

